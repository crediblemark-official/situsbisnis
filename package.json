{
  "name": "next-cms",
  "version": "1.0.0",
  "private": true,
  "type": "module",
  "scripts": {
    "dev": "NODE_OPTIONS='--max-old-space-size=4096' next dev --turbo",
    "dev:webpack": "NODE_OPTIONS='--max-old-space-size=4096' next dev",
    "clean": "rm -rf .next",
    "kill": "killall node || true",
    "build": "prisma generate && cpus=2 next build",
    "start": "NODE_OPTIONS='--optimize-for-size --gc-interval=100' node .next/standalone/server.js",
    "start:standalone": "NODE_OPTIONS='--optimize-for-size --gc-interval=100' node .next/standalone/server.js",
    "lint": "eslint .",
    "lint:fix": "eslint . --fix",
    "typecheck": "tsc --noEmit",
    "prisma:generate": "prisma generate",
    "prisma:deploy": "prisma migrate deploy",
    "test": "vitest",
    "test:ui": "vitest --ui",
    "test:coverage": "vitest run --coverage",
    "test:unit": "vitest run --exclude tests/e2e",
    "test:architecture": "depcruise src/modules",
    "test:e2e": "playwright test",
    "db:studio": "prisma studio",
    "db:push": "prisma db push",
    "prepare": "husky",
    "security:audit": "bun audit --level moderate",
    "deps:check": "bunx depcheck --ignores='@types/*,eslint-config-next,tsconfig,@playwright/test'"
  },
  "dependencies": {
    "@auth/prisma-adapter": "^2.11.2",
    "@aws-sdk/client-s3": "^3.1057.0",
    "@crediblemark/buayar": "^0.1.9",
    "@crediblemark/build": "^0.25.20",
    "@crediblemark/build-ai": "^0.1.10",
    "@crediblemark/build-ui": "^0.25.20",
    "@crediblemark/starsender": "^0.1.0",
    "@next/third-parties": "^16.2.6",
    "@prisma/client": "^5.22.0",
    "@sentry/nextjs": "^10.55.0",
    "@tiptap/core": "^3.24.0",
    "@tiptap/extension-image": "^3.24.0",
    "@tiptap/html": "^3.24.0",
    "@tiptap/pm": "^3.24.0",
    "@tiptap/react": "^3.24.0",
    "@tiptap/starter-kit": "^3.24.0",
    "bcryptjs": "^2.4.3",
    "ioredis": "^5.11.0",
    "lucide-react": "^0.556.0",
    "next": "^16.2.6",
    "next-auth": "^4.24.14",
    "next-themes": "^0.4.6",
    "pino": "^10.3.1",
    "react": "^19.2.6",
    "react-dom": "^19.2.6",
    "react-hot-toast": "^2.6.0",
    "resend": "^6.12.4",
    "sharp": "^0.34.5",
    "zod": "^4.4.3"
  },
  "devDependencies": {
    "@asteasolutions/zod-to-openapi": "^8.5.0",
    "@axe-core/playwright": "^4.11.3",
    "@playwright/test": "^1.60.0",
    "@tailwindcss/postcss": "^4.3.0",
    "@types/bcryptjs": "^2.4.6",
    "@types/ioredis": "^5.0.0",
    "@types/node": "^24.12.4",
    "@types/react": "^19.2.15",
    "@types/react-dom": "^19.2.3",
    "@vitest/coverage-v8": "2.1.9",
    "dependency-cruiser": "^17.4.3",
    "eslint": "9.21.0",
    "eslint-config-next": "^16.2.6",
    "happy-dom": "^16.8.1",
    "husky": "^9.1.7",
    "lint-staged": "^17.0.7",
    "pino-pretty": "^13.1.3",
    "postcss": "^8.5.15",
    "prettier": "^3.8.3",
    "prisma": "^5.22.0",
    "tailwindcss": "^4.3.0",
    "typescript": "^5.9.3",
    "vitest": "^2.1.9"
  },
  "prisma": {
    "seed": "bun prisma/init.cjs"
  },
  "lint-staged": {
    "*.{ts,tsx}": [
      "eslint --fix",
      "bash -c 'tsc --noEmit'"
    ],
    "*.{json,md}": [
      "prettier --write"
    ]
  },
  "knip": {
    "ignoreDependencies": [
      "pino-pretty"
    ],
    "ignoreBinaries": [
      "killall"
    ]
  }
}
