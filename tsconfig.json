{
  "extends": "./tsconfig/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/components/ui/FormRichText": ["./src/modules/content/ui/editor/FormRichText"],
      "@/components/ui/FormMediaPicker": ["./src/modules/content/ui/credbuild/FormMediaPicker"],
      "@/components/ui/GallerySection": ["./src/modules/content/ui/GallerySection"],
      "@/components/shop/*": ["./src/modules/catalog/ui/shop/*"],
      "@/components/credbuild/*": ["./src/modules/content/ui/credbuild/*"],
      "@/components/editor/*": ["./src/modules/content/ui/editor/*"],
      "@/components/blog/*": ["./src/modules/content/ui/blog/*"],
      "@/components/dashboard/media/*": ["./src/modules/content/ui/dashboard/media/*"],
      "@/components/dashboard/pages/*": ["./src/modules/content/ui/dashboard/pages/*"],
      "@/components/dashboard/products/*": ["./src/modules/catalog/ui/dashboard/products/*"],
      "@/components/dashboard/checkout/*": ["./src/modules/order/ui/dashboard/checkout/*"],
      "@/components/dashboard/users/*": ["./src/modules/auth/ui/dashboard/users/*"],
      "@/components/dashboard/billing/*": ["./src/modules/billing/ui/dashboard/billing/*"],
      "@/components/dashboard/subscriptions/*": ["./src/modules/billing/ui/dashboard/subscriptions/*"],
      "@/components/dashboard/settings/*": ["./src/modules/tenant/ui/dashboard/settings/*"],
      "@/components/admin/settings/*": ["./src/modules/tenant/ui/admin/settings/*"],
      "@/components/site/checkout/*": ["./src/modules/order/ui/site/checkout/*"],
      "@/components/site/*": ["./src/modules/tenant/ui/site/*"],
      "@/components/admin/BackupClient": ["./src/modules/tenant/ui/admin/BackupClient"],
      "@/components/admin/CouponList": ["./src/modules/auth/ui/admin/CouponList"],
      "@/components/admin/TransactionList": ["./src/modules/auth/ui/admin/TransactionList"],
      "@/components/admin/WithdrawalList": ["./src/modules/auth/ui/admin/WithdrawalList"],
      "@/components/dashboard/BillingClient": ["./src/modules/billing/ui/dashboard/BillingClient"],
      "@/components/dashboard/HistoryBillClient": ["./src/modules/billing/ui/dashboard/HistoryBillClient"],
      "@/components/*": ["./src/modules/shared/ui/*"],
      "@/lib/*": ["./src/modules/shared/utils/*"],
      "@/lib/core/*": ["./src/modules/shared/core/*"],
      "@/hooks/*": ["./src/modules/shared/hooks/*"],
      "@/themes/*": ["./src/modules/shared/themes/*"],
      "@/types/*": ["./src/modules/shared/types/*"],
      "@crediblemark/build": ["./node_modules/@crediblemark/build"],
      "@tiptap/core": ["./node_modules/@tiptap/core"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "packages", "scratch"]
}
