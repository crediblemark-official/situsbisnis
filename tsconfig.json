{
  "extends": "./tsconfig/nextjs.json",
  "compilerOptions": {
    "plugins": [
      {
        "name": "next"
      }
    ],
    "baseUrl": ".",
    "moduleResolution": "bundler",
    "paths": {
      "@/*": ["./src/*"],
      "@/modules/*": ["./src/modules/*"],
      "@/lib/modules/identity/client": ["./src/modules/auth"],
      "@/lib/modules/identity/types": ["./src/modules/auth"],
      "@/lib/modules/identity/*": ["./src/modules/auth/*"],
      "@/lib/modules/*/client": ["./src/modules/*"],
      "@/lib/modules/*/types": ["./src/modules/*"],
      "@/lib/modules/*": ["./src/modules/*"],
      "@/components/*": ["./src/modules/shared/ui/*"],
      "@/lib/*": ["./src/modules/shared/utils/*"],
      "@/lib/core/*": ["./src/modules/shared/core/*"],
      "@/hooks/*": ["./src/modules/shared/hooks/*"],
      "@/themes/*": ["./src/modules/shared/themes/*"],
      "@/types/*": ["./src/modules/shared/types/*"],
      "@crediblemark/build": ["./node_modules/@crediblemark/build"],
      "@tiptap/core": ["./node_modules/@tiptap/core"]
    }
  },
  "include": ["next-env.d.ts", "**/*.ts", "**/*.tsx", ".next/types/**/*.ts"],
  "exclude": ["node_modules", "packages", "scratch"]
}
