# ============================================
# Required Environment Variables
# ============================================

# Database (Prisma main connection)
DATABASE_URL="postgresql://user:password@host:5432/dbname?schema=public&connection_limit=10"

# Batas maksimum koneksi pooling database (Opsional. Default: 5 di dev, 25 di prod)
# DATABASE_CONNECTION_LIMIT=25

# Direct URL (Used for direct prisma migrations)
DIRECT_URL="postgresql://user:password@host:5432/dbname?schema=public"

# NextAuth Configuration
NEXTAUTH_SECRET="your-secret-key-at-least-32-characters-long"
NEXTAUTH_URL="https://situsbisnis.com"

# Application Settings
NEXT_PUBLIC_APP_URL="https://situsbisnis.com"
NEXT_PUBLIC_ROOT_DOMAIN="situsbisnis.com"
NEXT_PUBLIC_SERVER_IP="168.231.119.22"

# Redis Cache Service
REDIS_URL="redis://default:password@host:6379"

# ============================================
# Optional - Sentry Error Monitoring
# ============================================
# NEXT_PUBLIC_SENTRY_DSN=
# SENTRY_ORG=
# SENTRY_PROJECT=

# ============================================
# Optional - Logging
# ============================================
# LOG_LEVEL=debug

# ============================================
# Optional - Defaults (can be overridden)
# ============================================
# DEFAULT_SITE_NAME=SitusBisnis
# DEFAULT_SITE_DESC=Platform Website Instan
# DEFAULT_BANK_NAME=Example Bank
# DEFAULT_BANK_ACCOUNT=0000000000
# DEFAULT_BANK_HOLDER=Store Owner
# DEFAULT_CURRENCY=IDR
# DEFAULT_THEME=default
# DEFAULT_BRAND_COLOR=#0ea5e9

# ============================================
# Optional - AI Provider (set ONE key only)
# ============================================
# GEMINI_API_KEY=
# OPENAI_API_KEY=
# OPENROUTER_API_KEY=
# GROQ_API_KEY=
# NVIDIA_API_KEY=

# ============================================
# Optional - Email Provider
# ============================================
# RESEND_API_KEY=
